---
const { title, description, canonical } = Astro.props;
import { PHONE, PHONE_LINK, BRAND, TAGLINE } from '../lib/cities.js';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@600;700;800&family=Barlow:wght@400;500;600&display=swap" rel="stylesheet" />

  <!-- Google Ads tracking — uncomment and replace AW-XXXXX with your tag ID -->
  <!-- <script async src="https://www.googletagmanager.com/gtag/js?id=AW-XXXXX"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'AW-XXXXX');
  </script> -->

  <style>
    :root {
      --steel-950: #0a0e14;
      --steel-900: #111822;
      --steel-800: #1a2332;
      --steel-700: #243044;
      --steel-600: #364a66;
      --steel-500: #5a7599;
      --steel-400: #8aa4c4;
      --steel-300: #b8cce0;
      --steel-200: #dce6f0;
      --steel-100: #f0f4f8;
      --amber-500: #f59e0b;
      --amber-400: #fbbf24;
      --amber-300: #fcd34d;
      --red-600: #dc2626;
      --red-500: #ef4444;
      --white: #ffffff;
      --font-display: 'Barlow Condensed', sans-serif;
      --font-body: 'Barlow', sans-serif;
    }

    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    html { scroll-behavior: smooth; }

    body {
      font-family: var(--font-body);
      background: var(--steel-950);
      color: var(--steel-200);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }

    .container { max-width: 1100px; margin: 0 auto; padding: 0 24px; }

    /* ── HEADER ─────────────────────────────────────── */
    .header {
      background: var(--steel-900);
      border-bottom: 2px solid var(--amber-500);
      padding: 0;
      position: sticky;
      top: 0;
      z-index: 100;
    }
    .header-inner {
      max-width: 1100px;
      margin: 0 auto;
      padding: 14px 24px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .header-brand {
      display: flex;
      flex-direction: row;
      align-items: center;
      gap: 12px;
    }
    .header-logo {
      height: 44px;
      width: auto;
    }
    .header-text {
      display: flex;
      flex-direction: column;
    }
    .header-name {
      font-family: var(--font-display);
      font-weight: 800;
      font-size: 1.4rem;
      color: var(--white);
      text-transform: uppercase;
      letter-spacing: 0.04em;
      line-height: 1.1;
    }
    .header-tagline {
      font-family: var(--font-display);
      font-weight: 600;
      font-size: 0.8rem;
      color: var(--amber-400);
      text-transform: uppercase;
      letter-spacing: 0.12em;
    }
    .header-phone a {
      display: flex;
      align-items: center;
      gap: 8px;
      background: var(--amber-500);
      color: var(--steel-950);
      padding: 10px 20px;
      border-radius: 4px;
      font-family: var(--font-display);
      font-weight: 700;
      font-size: 1.1rem;
      text-decoration: none;
      letter-spacing: 0.02em;
      transition: background 0.2s;
    }
    .header-phone a:hover { background: var(--amber-400); }
    .header-phone svg { width: 18px; height: 18px; }

    /* ── HERO ───────────────────────────────────────── */
    .hero {
      background:
        linear-gradient(170deg, rgba(10,14,20,0.92) 0%, rgba(17,24,34,0.88) 50%, rgba(26,35,50,0.85) 100%),
        repeating-linear-gradient(
          0deg,
          transparent,
          transparent 40px,
          rgba(245,158,11,0.03) 40px,
          rgba(245,158,11,0.03) 41px
        ),
        repeating-linear-gradient(
          90deg,
          transparent,
          transparent 40px,
          rgba(245,158,11,0.03) 40px,
          rgba(245,158,11,0.03) 41px
        );
      padding: 80px 0 90px;
      text-align: center;
      border-bottom: 3px solid var(--amber-500);
    }
    .hero-badge {
      display: inline-block;
      background: rgba(245,158,11,0.12);
      border: 1px solid rgba(245,158,11,0.3);
      color: var(--amber-400);
      font-family: var(--font-display);
      font-weight: 700;
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      padding: 6px 18px;
      border-radius: 3px;
      margin-bottom: 20px;
    }
    .hero h1 {
      font-family: var(--font-display);
      font-weight: 800;
      font-size: clamp(2.4rem, 5.5vw, 4rem);
      color: var(--white);
      text-transform: uppercase;
      letter-spacing: 0.02em;
      line-height: 1.05;
      margin-bottom: 16px;
    }
    .hero h1 span { color: var(--amber-400); }
    .hero-sub {
      font-size: 1.15rem;
      color: var(--steel-300);
      max-width: 660px;
      margin: 0 auto 32px;
      line-height: 1.6;
    }
    .hero-cta {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      background: var(--amber-500);
      color: var(--steel-950);
      padding: 16px 36px;
      border-radius: 4px;
      font-family: var(--font-display);
      font-weight: 800;
      font-size: 1.3rem;
      text-decoration: none;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      transition: background 0.2s, transform 0.15s;
    }
    .hero-cta:hover { background: var(--amber-400); transform: translateY(-1px); }
    .hero-cta svg { width: 22px; height: 22px; }

    /* ── TRUST BAR ──────────────────────────────────── */
    .trust-bar {
      background: var(--steel-900);
      padding: 24px 0;
      border-bottom: 1px solid var(--steel-700);
    }
    .trust-items {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 12px 28px;
    }
    .trust-item {
      display: flex;
      align-items: center;
      gap: 6px;
      font-family: var(--font-display);
      font-weight: 600;
      font-size: 0.85rem;
      color: var(--steel-300);
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }
    .trust-item::before {
      content: '✓';
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 20px;
      height: 20px;
      background: rgba(245,158,11,0.15);
      color: var(--amber-400);
      border-radius: 3px;
      font-size: 0.7rem;
      font-weight: 800;
      flex-shrink: 0;
    }

    /* ── SERVICES ───────────────────────────────────── */
    .services {
      padding: 80px 0;
      background: var(--steel-950);
    }
    .section-label {
      font-family: var(--font-display);
      font-weight: 700;
      font-size: 0.8rem;
      color: var(--amber-400);
      text-transform: uppercase;
      letter-spacing: 0.15em;
      text-align: center;
      margin-bottom: 10px;
    }
    .section-title {
      font-family: var(--font-display);
      font-weight: 800;
      font-size: clamp(1.8rem, 4vw, 2.6rem);
      color: var(--white);
      text-transform: uppercase;
      text-align: center;
      margin-bottom: 50px;
      letter-spacing: 0.02em;
    }
    .services-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
    }
    .service-card {
      background: var(--steel-900);
      border: 1px solid var(--steel-700);
      border-radius: 6px;
      padding: 28px 24px;
      transition: border-color 0.2s, transform 0.15s;
    }
    .service-card:hover {
      border-color: var(--amber-500);
      transform: translateY(-2px);
    }
    .service-icon {
      font-size: 1.8rem;
      margin-bottom: 12px;
    }
    .service-card h3 {
      font-family: var(--font-display);
      font-weight: 700;
      font-size: 1.1rem;
      color: var(--white);
      text-transform: uppercase;
      letter-spacing: 0.02em;
      margin-bottom: 8px;
    }
    .service-card p {
      font-size: 0.9rem;
      color: var(--steel-400);
      line-height: 1.5;
    }

    /* ── ABOUT / CAPABILITY ────────────────────────── */
    .about {
      padding: 80px 0;
      background: var(--steel-900);
      border-top: 1px solid var(--steel-700);
      border-bottom: 1px solid var(--steel-700);
    }
    .about-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 50px;
      align-items: start;
    }
    .about-text h2 {
      font-family: var(--font-display);
      font-weight: 800;
      font-size: clamp(1.6rem, 3.5vw, 2.2rem);
      color: var(--white);
      text-transform: uppercase;
      margin-bottom: 18px;
      letter-spacing: 0.02em;
    }
    .about-text p {
      color: var(--steel-300);
      margin-bottom: 16px;
      line-height: 1.7;
    }
    .about-text p strong { color: var(--amber-400); font-weight: 600; }
    .about-stats {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
    }
    .stat-card {
      background: var(--steel-800);
      border: 1px solid var(--steel-700);
      border-radius: 6px;
      padding: 24px 20px;
      text-align: center;
    }
    .stat-number {
      font-family: var(--font-display);
      font-weight: 800;
      font-size: 2rem;
      color: var(--amber-400);
      line-height: 1;
      margin-bottom: 4px;
    }
    .stat-label {
      font-family: var(--font-display);
      font-weight: 600;
      font-size: 0.75rem;
      color: var(--steel-400);
      text-transform: uppercase;
      letter-spacing: 0.1em;
    }

    /* ── AREA COVERAGE ─────────────────────────────── */
    .coverage {
      padding: 70px 0;
      background: var(--steel-950);
    }
    .coverage-text {
      text-align: center;
      max-width: 700px;
      margin: 0 auto 30px;
    }
    .coverage-text p {
      color: var(--steel-300);
      line-height: 1.6;
    }
    .area-tags {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 10px;
      margin-bottom: 16px;
    }
    .area-tag {
      background: var(--steel-800);
      border: 1px solid var(--steel-700);
      color: var(--steel-200);
      font-family: var(--font-display);
      font-weight: 600;
      font-size: 0.85rem;
      padding: 8px 16px;
      border-radius: 4px;
      letter-spacing: 0.02em;
    }
    .route-tags {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 8px;
    }
    .route-tag {
      background: rgba(245,158,11,0.1);
      border: 1px solid rgba(245,158,11,0.25);
      color: var(--amber-400);
      font-family: var(--font-display);
      font-weight: 700;
      font-size: 0.8rem;
      padding: 5px 14px;
      border-radius: 3px;
      letter-spacing: 0.06em;
    }

    /* ── CTA SECTION ───────────────────────────────── */
    .cta-section {
      padding: 80px 0;
      background:
        linear-gradient(170deg, var(--steel-900) 0%, var(--steel-800) 100%);
      text-align: center;
      border-top: 3px solid var(--amber-500);
    }
    .cta-section h2 {
      font-family: var(--font-display);
      font-weight: 800;
      font-size: clamp(1.8rem, 4vw, 2.8rem);
      color: var(--white);
      text-transform: uppercase;
      margin-bottom: 10px;
    }
    .cta-section .cta-sub {
      color: var(--steel-300);
      font-size: 1.1rem;
      margin-bottom: 30px;
    }

    /* ── FOOTER ─────────────────────────────────────── */
    .footer {
      background: var(--steel-950);
      border-top: 1px solid var(--steel-700);
      padding: 40px 0;
      text-align: center;
    }
    .footer p { color: var(--steel-500); font-size: 0.85rem; }
    .footer a { color: var(--amber-400); text-decoration: none; }

    /* ── MOBILE STICKY CTA ─────────────────────────── */
    .mobile-cta {
      display: none;
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      background: var(--amber-500);
      padding: 14px 24px;
      z-index: 200;
      box-shadow: 0 -4px 20px rgba(0,0,0,0.4);
    }
    .mobile-cta a {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      color: var(--steel-950);
      font-family: var(--font-display);
      font-weight: 800;
      font-size: 1.2rem;
      text-decoration: none;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }
    .mobile-cta svg { width: 22px; height: 22px; }

    /* ── RESPONSIVE ─────────────────────────────────── */
    @media (max-width: 900px) {
      .services-grid { grid-template-columns: repeat(2, 1fr); }
      .about-grid { grid-template-columns: 1fr; gap: 40px; }
    }
    @media (max-width: 640px) {
      .hero { padding: 50px 0 60px; }
      .hero h1 { font-size: 2rem; }
      .hero-sub { font-size: 1rem; }
      .services-grid { grid-template-columns: 1fr; }
      .about-stats { grid-template-columns: 1fr 1fr; }
      .trust-items { gap: 8px 20px; }
      .trust-item { font-size: 0.75rem; }
      .header-text { display: none; }
      .mobile-cta { display: block; }
      body { padding-bottom: 60px; }
      .cta-section { padding: 50px 0; }
      .header-phone a { font-size: 0.95rem; padding: 8px 16px; }
    }
  </style>
</head>
<body>
  <slot />
</body>
</html>
