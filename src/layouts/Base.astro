---
const { title, description, canonical } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical || 'https://towtruck.cv'} />

  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonical || 'https://towtruck.cv'} />
  <meta property="og:site_name" content="Professional Dispatch" />

  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />

  <link rel="icon" type="image/svg+xml" href="/logo.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />

  <!-- Google Ads Global Site Tag -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=AW-18018086695" is:inline></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'AW-18018086695');
  </script>

  <style is:global>
    :root {
      --navy: #0a0f1a;
      --navy-light: #111827;
      --slate: #1e293b;
      --gold: #f59e0b;
      --gold-light: #fbbf24;
      --gold-dark: #d97706;
      --white: #ffffff;
      --gray-50: #f8fafc;
      --gray-100: #f1f5f9;
      --gray-200: #e2e8f0;
      --gray-300: #cbd5e1;
      --gray-400: #94a3b8;
      --gray-500: #64748b;
      --gray-600: #475569;
      --gray-700: #334155;
      --gray-800: #1e293b;
      --gray-900: #0f172a;
      --red: #ef4444;
      --red-dark: #dc2626;
      --green: #22c55e;
      --font: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      --shadow-sm: 0 1px 2px rgba(0,0,0,.05);
      --shadow-md: 0 4px 6px -1px rgba(0,0,0,.1), 0 2px 4px -2px rgba(0,0,0,.1);
      --shadow-lg: 0 10px 15px -3px rgba(0,0,0,.1), 0 4px 6px -4px rgba(0,0,0,.1);
      --shadow-xl: 0 20px 25px -5px rgba(0,0,0,.1), 0 8px 10px -6px rgba(0,0,0,.1);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }
    body { font-family: var(--font); color: var(--gray-800); background: var(--white); line-height: 1.6; }

    /* HEADER */
    .header {
      background: rgba(10,15,26,.95);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(245,158,11,.2);
      position: sticky; top: 0; z-index: 100;
    }
    .header-inner { display: flex; align-items: center; justify-content: space-between; padding: 14px 24px; max-width: 1200px; margin: 0 auto; }
    .header-logo { display: flex; align-items: center; gap: 12px; text-decoration: none; }
    .header-logo img { height: 40px; width: auto; max-width: 40px; object-fit: contain; }
    .header-brand { font-size: 1.15rem; font-weight: 800; color: var(--white); letter-spacing: -0.03em; }
    .header-brand span { color: var(--gold); }
    .header-phone {
      display: flex; align-items: center; gap: 8px;
      background: linear-gradient(135deg, var(--gold) 0%, var(--gold-dark) 100%);
      color: var(--navy); font-weight: 700; font-size: 1rem;
      padding: 10px 22px; border-radius: 10px; text-decoration: none;
      transition: all 0.2s; letter-spacing: 0.01em;
      box-shadow: 0 2px 8px rgba(245,158,11,.3);
    }
    .header-phone:hover { transform: translateY(-1px); box-shadow: 0 4px 16px rgba(245,158,11,.4); }
    .header-phone svg { width: 18px; height: 18px; animation: ring 3s ease-in-out infinite; }

    @keyframes ring {
      0%, 100% { transform: rotate(0deg); }
      3% { transform: rotate(15deg); }
      6% { transform: rotate(-12deg); }
      9% { transform: rotate(8deg); }
      12% { transform: rotate(0deg); }
    }

    /* HERO */
    .hero {
      background: var(--navy);
      padding: 80px 0 96px;
      position: relative; overflow: hidden;
    }
    .hero::before {
      content: ''; position: absolute; inset: 0;
      background:
        radial-gradient(ellipse 80% 60% at 50% 0%, rgba(245,158,11,.08) 0%, transparent 60%),
        radial-gradient(ellipse 60% 50% at 80% 100%, rgba(59,130,246,.06) 0%, transparent 50%);
      pointer-events: none;
    }
    .hero::after {
      content: ''; position: absolute; inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg width='40' height='40' viewBox='0 0 40 40' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='%23ffffff' fill-opacity='0.02'%3E%3Ccircle cx='20' cy='20' r='1'/%3E%3C/g%3E%3C/svg%3E");
      pointer-events: none;
    }
    .hero-content { position: relative; max-width: 800px; margin: 0 auto; padding: 0 24px; text-align: center; }
    .hero-badge {
      display: inline-flex; align-items: center; gap: 8px;
      background: rgba(34,197,94,.1); border: 1px solid rgba(34,197,94,.25);
      color: var(--green); font-size: 0.8rem; font-weight: 600;
      padding: 6px 16px; border-radius: 100px; margin-bottom: 28px;
      letter-spacing: 0.06em; text-transform: uppercase;
    }
    .hero-badge-dot { width: 7px; height: 7px; background: var(--green); border-radius: 50%; animation: pulse 2s ease-in-out infinite; box-shadow: 0 0 8px rgba(34,197,94,.6); }
    @keyframes pulse { 0%, 100% { opacity: 1; transform: scale(1); } 50% { opacity: .6; transform: scale(1.4); } }
    .hero h1 { font-size: clamp(2.4rem, 5.5vw, 4rem); font-weight: 900; color: var(--white); line-height: 1.08; margin-bottom: 20px; letter-spacing: -0.04em; }
    .hero h1 em { font-style: normal; background: linear-gradient(135deg, var(--gold-light), var(--gold-dark)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
    .hero-sub { font-size: 1.15rem; color: var(--gray-400); max-width: 560px; margin: 0 auto 36px; line-height: 1.7; }
    .hero-cta-wrap { display: flex; flex-direction: column; align-items: center; gap: 14px; }
    .btn-call {
      display: inline-flex; align-items: center; gap: 10px;
      background: linear-gradient(135deg, var(--red) 0%, var(--red-dark) 100%);
      color: var(--white); font-weight: 800; font-size: 1.2rem;
      padding: 18px 42px; border-radius: 14px; text-decoration: none;
      transition: all 0.2s;
      box-shadow: 0 4px 24px rgba(239,68,68,.35), inset 0 1px 0 rgba(255,255,255,.15);
      letter-spacing: 0.01em;
    }
    .btn-call:hover { transform: translateY(-2px); box-shadow: 0 8px 32px rgba(239,68,68,.45), inset 0 1px 0 rgba(255,255,255,.15); }
    .btn-call svg { width: 22px; height: 22px; }
    .hero-trust { color: var(--gray-500); font-size: 0.85rem; display: flex; align-items: center; gap: 16px; justify-content: center; flex-wrap: wrap; }
    .hero-trust span { display: flex; align-items: center; gap: 5px; }
    .hero-trust-dot { width: 4px; height: 4px; background: var(--gray-600); border-radius: 50%; }

    /* STATS BAR */
    .stats-bar {
      background: var(--white);
      border-bottom: 1px solid var(--gray-200);
      padding: 0;
    }
    .stats-items {
      display: grid; grid-template-columns: repeat(4, 1fr);
      max-width: 1000px; margin: 0 auto;
    }
    .stat-item {
      text-align: center; padding: 28px 16px;
      border-right: 1px solid var(--gray-200);
    }
    .stat-item:last-child { border-right: none; }
    .stat-number { font-size: 1.6rem; font-weight: 900; color: var(--navy); letter-spacing: -0.03em; line-height: 1; }
    .stat-number span { color: var(--gold-dark); }
    .stat-label { font-size: 0.78rem; font-weight: 600; color: var(--gray-500); text-transform: uppercase; letter-spacing: 0.08em; margin-top: 6px; }

    /* SERVICES */
    .services { padding: 80px 0; background: var(--gray-50); }
    .section-label {
      font-size: 0.8rem; font-weight: 700; color: var(--gold-dark);
      text-transform: uppercase; letter-spacing: 0.1em;
      text-align: center; margin-bottom: 10px;
    }
    .section-title {
      font-size: clamp(1.8rem, 3.5vw, 2.4rem); font-weight: 800;
      color: var(--navy); text-align: center; margin-bottom: 16px;
      letter-spacing: -0.03em;
    }
    .section-subtitle {
      font-size: 1.05rem; color: var(--gray-500); text-align: center;
      max-width: 520px; margin: 0 auto 48px;
    }
    .services-grid {
      display: grid; grid-template-columns: repeat(3, 1fr);
      gap: 20px; max-width: 1100px; margin: 0 auto; padding: 0 24px;
    }
    .service-card {
      background: var(--white); border: 1px solid var(--gray-200);
      border-radius: 16px; padding: 32px 28px;
      transition: all 0.25s; position: relative;
      box-shadow: var(--shadow-sm);
    }
    .service-card:hover {
      border-color: var(--gold);
      box-shadow: var(--shadow-lg), 0 0 0 1px rgba(245,158,11,.1);
      transform: translateY(-4px);
    }
    .service-icon {
      width: 48px; height: 48px;
      background: linear-gradient(135deg, var(--navy) 0%, var(--slate) 100%);
      border-radius: 12px; display: flex; align-items: center; justify-content: center;
      margin-bottom: 20px; color: var(--gold); font-size: 1.3rem;
      box-shadow: 0 2px 8px rgba(10,15,26,.15);
    }
    .service-icon svg { width: 24px; height: 24px; stroke: var(--gold); fill: none; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }
    .service-card h3 {
      font-size: 1.05rem; font-weight: 700; color: var(--navy);
      margin-bottom: 10px; letter-spacing: -0.01em;
    }
    .service-card p { font-size: 0.9rem; color: var(--gray-500); line-height: 1.65; }

    /* AREAS */
    .areas {
      background: var(--navy); padding: 72px 0; position: relative; overflow: hidden;
    }
    .areas::before {
      content: ''; position: absolute; inset: 0;
      background: radial-gradient(ellipse 60% 60% at 20% 50%, rgba(245,158,11,.06) 0%, transparent 60%);
      pointer-events: none;
    }
    .areas .section-label { color: var(--gold-light); }
    .areas .section-title { color: var(--white); }
    .areas .section-subtitle { color: var(--gray-400); }
    .areas-list {
      display: flex; flex-wrap: wrap; justify-content: center;
      gap: 10px; max-width: 900px; margin: 0 auto; padding: 0 24px;
      position: relative;
    }
    .area-tag {
      background: rgba(255,255,255,.06);
      border: 1px solid rgba(255,255,255,.1);
      color: var(--gray-300); font-weight: 500; font-size: 0.88rem;
      padding: 10px 20px; border-radius: 10px; transition: all 0.2s;
    }
    .area-tag:hover {
      background: rgba(245,158,11,.12);
      border-color: rgba(245,158,11,.3);
      color: var(--gold-light);
      transform: translateY(-1px);
    }

    /* CTA */
    .cta-section {
      padding: 80px 0; text-align: center;
      background: linear-gradient(180deg, var(--white) 0%, var(--gray-50) 100%);
      position: relative;
    }
    .cta-section::before {
      content: ''; position: absolute; top: 0; left: 50%; transform: translateX(-50%);
      width: 120px; height: 3px; border-radius: 3px;
      background: linear-gradient(90deg, var(--gold), var(--gold-dark));
    }
    .cta-section h2 {
      font-size: clamp(1.8rem, 3.5vw, 2.6rem); font-weight: 900;
      color: var(--navy); margin-bottom: 12px; letter-spacing: -0.03em;
    }
    .cta-section p { color: var(--gray-500); font-size: 1.1rem; margin-bottom: 36px; max-width: 440px; margin-left: auto; margin-right: auto; }

    /* FOOTER */
    .footer {
      background: var(--navy); border-top: 1px solid rgba(255,255,255,.08);
      padding: 48px 0 40px; text-align: center;
    }
    .footer-brand { font-size: 1.1rem; font-weight: 800; color: var(--white); margin-bottom: 8px; }
    .footer-brand span { color: var(--gold); }
    .footer p { color: var(--gray-500); font-size: 0.82rem; }
    .footer a { color: var(--gold); text-decoration: none; font-weight: 600; }
    .footer a:hover { color: var(--gold-light); }

    /* MOBILE STICKY CTA */
    .mobile-cta {
      display: none; position: fixed; bottom: 0; left: 0; right: 0;
      background: linear-gradient(135deg, var(--red) 0%, var(--red-dark) 100%);
      padding: 16px 24px; z-index: 200;
      box-shadow: 0 -4px 24px rgba(0,0,0,.25);
    }
    .mobile-cta a {
      display: flex; align-items: center; justify-content: center; gap: 10px;
      color: var(--white); font-weight: 800; font-size: 1.15rem; text-decoration: none;
    }
    .mobile-cta svg { width: 22px; height: 22px; }

    /* RESPONSIVE */
    @media (max-width: 900px) {
      .services-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 768px) {
      .hero { padding: 56px 0 72px; }
      .hero h1 { font-size: 2.2rem; }
      .hero-sub { font-size: 1rem; }
      .btn-call { font-size: 1.1rem; padding: 16px 32px; }
      .services { padding: 56px 0; }
      .services-grid { grid-template-columns: 1fr; max-width: 480px; }
      .stats-items { grid-template-columns: repeat(2, 1fr); }
      .stat-item:nth-child(2) { border-right: none; }
      .stat-item { padding: 20px 12px; }
      .stat-number { font-size: 1.3rem; }
      .header-brand { display: none; }
      .mobile-cta { display: block; }
      body { padding-bottom: 64px; }
      .cta-section { padding: 56px 0; }
      .areas { padding: 56px 0; }
    }
  </style>
</head>
<body>
  <slot />
</body>
</html>
