---
const { title, description, canonical } = Astro.props;
import { PHONE, PHONE_LINK, BRAND, TAGLINE } from '../lib/cities.js';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  {canonical && <link rel="canonical" href={canonical} />}
  <link rel="icon" type="image/svg+xml" href="/logo.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@600;700;800;900&family=Barlow:wght@400;500;600;700&display=swap" rel="stylesheet" />

  <!-- Google Ads — replace AW-XXXXX with your tag ID -->
  <!-- <script async src="https://www.googletagmanager.com/gtag/js?id=AW-XXXXX"></script>
  <script>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','AW-XXXXX');</script> -->

  <style is:global>
    :root {
      --bg: #0a0c0f; --bg2: #141618; --bg3: #1e2124;
      --border: #2a2d31; --border2: #3a3e42;
      --text: #e8e8e8; --text2: #c8c8c8; --text3: #8a8a8a; --text4: #5a5a5a;
      --accent: #CCFF00; --accent2: #B8FF00; --accent3: #E0FF66;
      --white: #ffffff;
      --fd: 'Barlow Condensed', sans-serif;
      --fb: 'Barlow', sans-serif;
    }
    *,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
    html{scroll-behavior:smooth;}
    body{font-family:var(--fb);background:var(--bg);color:var(--text);line-height:1.6;-webkit-font-smoothing:antialiased;}
    .container{max-width:1100px;margin:0 auto;padding:0 24px;}
    img{max-width:100%;height:auto;display:block;}

    /* ── HEADER ──────────────────────────── */
    .header{background:var(--bg2);border-bottom:2px solid var(--accent);position:sticky;top:0;z-index:100;}
    .header-inner{max-width:1100px;margin:0 auto;padding:14px 24px;display:flex;align-items:center;justify-content:space-between;}
    .header-brand{display:flex;align-items:center;gap:12px;}
    .header-logo{height:44px;width:auto;}
    .header-text{display:flex;flex-direction:column;}
    .header-name{font-family:var(--fd);font-weight:800;font-size:1.4rem;color:var(--white);text-transform:uppercase;letter-spacing:.04em;line-height:1.1;}
    .header-tagline{font-family:var(--fd);font-weight:600;font-size:.8rem;color:var(--accent2);text-transform:uppercase;letter-spacing:.12em;}
    .header-phone a{display:flex;align-items:center;gap:8px;background:var(--accent);color:var(--bg);padding:10px 20px;border-radius:4px;font-family:var(--fd);font-weight:700;font-size:1.1rem;text-decoration:none;transition:background .2s;}
    .header-phone a:hover{background:var(--accent2);}
    .header-phone svg{width:18px;height:18px;}

    /* ── HERO ─────────────────────────────── */
    .hero{position:relative;min-height:520px;display:flex;align-items:center;overflow:hidden;border-bottom:3px solid var(--accent);}
    .hero-bg{position:absolute;inset:0;}
    .hero-bg img{width:100%;height:100%;object-fit:cover;object-position:center 40%;}
    .hero-overlay{position:absolute;inset:0;background:linear-gradient(170deg,rgba(10,14,20,.88) 0%,rgba(17,24,34,.82) 50%,rgba(26,35,50,.75) 100%);}
    .hero-content{position:relative;z-index:2;padding:70px 0 80px;text-align:center;}
    .hero-badge{display:inline-block;background:rgba(204,255,0,.12);border:1px solid rgba(204,255,0,.3);color:var(--accent2);font-family:var(--fd);font-weight:700;font-size:.75rem;text-transform:uppercase;letter-spacing:.12em;padding:6px 18px;border-radius:3px;margin-bottom:20px;}
    .hero h1{font-family:var(--fd);font-weight:900;font-size:clamp(2.4rem,5.5vw,4.2rem);color:var(--white);text-transform:uppercase;letter-spacing:.02em;line-height:1.05;margin-bottom:16px;}
    .hero h1 span{color:var(--accent2);}
    .hero-sub{font-size:1.1rem;color:var(--text2);max-width:660px;margin:0 auto 32px;line-height:1.65;}
    .hero-actions{display:flex;gap:14px;justify-content:center;flex-wrap:wrap;}
    .btn-primary{display:inline-flex;align-items:center;gap:10px;background:var(--accent);color:var(--bg);padding:14px 30px;border-radius:4px;font-family:var(--fd);font-weight:800;font-size:1.15rem;text-decoration:none;text-transform:uppercase;letter-spacing:.04em;border:none;cursor:pointer;transition:background .2s,transform .15s;}
    .btn-primary:hover{background:var(--accent2);transform:translateY(-1px);}
    .btn-primary svg{width:20px;height:20px;}
    .btn-secondary{display:inline-flex;align-items:center;gap:10px;background:transparent;color:var(--white);border:2px solid rgba(255,255,255,.3);padding:12px 28px;border-radius:4px;font-family:var(--fd);font-weight:700;font-size:1.1rem;text-decoration:none;text-transform:uppercase;letter-spacing:.04em;transition:border-color .2s,background .2s;}
    .btn-secondary:hover{border-color:var(--accent);background:rgba(204,255,0,.08);}
    .btn-secondary svg{width:18px;height:18px;}

    /* ── CREDENTIALS BAR ─────────────────── */
    .cred-bar{background:var(--bg2);padding:28px 0;border-bottom:1px solid var(--border);}
    .cred-items{display:flex;justify-content:center;align-items:center;gap:32px;flex-wrap:wrap;}
    .cred-item{text-align:center;}
    .cred-number{font-family:var(--fd);font-weight:800;font-size:1.3rem;color:var(--accent2);text-transform:uppercase;letter-spacing:.04em;}
    .cred-label{font-family:var(--fd);font-weight:600;font-size:.7rem;color:var(--text3);text-transform:uppercase;letter-spacing:.1em;}
    .cred-divider{width:1px;height:36px;background:var(--border);}

    /* ── SECTION HELPERS ─────────────────── */
    .section-label{font-family:var(--fd);font-weight:700;font-size:.8rem;color:var(--accent2);text-transform:uppercase;letter-spacing:.15em;text-align:center;margin-bottom:8px;}
    .section-title{font-family:var(--fd);font-weight:800;font-size:clamp(1.8rem,4vw,2.6rem);color:var(--white);text-transform:uppercase;text-align:center;margin-bottom:50px;letter-spacing:.02em;}

    /* ── WHAT WE MOVE ────────────────────── */
    .wwm{padding:80px 0;background:var(--bg);}
    .move-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px;}
    .move-card{background:var(--bg2);border:1px solid var(--border);border-radius:6px;padding:28px 24px;transition:border-color .2s,transform .15s;}
    .move-card:hover{border-color:var(--accent);transform:translateY(-2px);}
    .move-card h3{font-family:var(--fd);font-weight:700;font-size:1.05rem;color:var(--white);text-transform:uppercase;letter-spacing:.02em;margin-bottom:8px;}
    .move-card p{font-size:.88rem;color:var(--text3);line-height:1.5;}

    /* ── FLEET GALLERY ───────────────────── */
    .fleet{padding:80px 0;background:var(--bg2);border-top:1px solid var(--border);border-bottom:1px solid var(--border);}
    .fleet-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:16px;margin-bottom:40px;}
    .fleet-wide{grid-column:span 2;}
    .fleet-photo{position:relative;border-radius:6px;overflow:hidden;background:var(--bg3);}
    .fleet-photo img{width:100%;height:100%;object-fit:cover;display:block;aspect-ratio:16/9;}
    .fleet-wide img{aspect-ratio:21/9;}
    .fleet-cap{position:absolute;bottom:0;left:0;right:0;background:linear-gradient(transparent,rgba(10,14,20,.85));padding:16px 16px 12px;font-family:var(--fd);font-weight:600;font-size:.8rem;color:var(--text2);text-transform:uppercase;letter-spacing:.06em;}
    .fleet-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;}
    .fs{background:var(--bg3);border:1px solid var(--border);border-radius:6px;padding:20px;text-align:center;}
    .fs strong{display:block;font-family:var(--fd);font-weight:700;font-size:1rem;color:var(--accent2);text-transform:uppercase;margin-bottom:4px;}
    .fs span{font-size:.8rem;color:var(--text3);line-height:1.4;}

    /* ── BUILDER SERVICES ────────────────── */
    .builders{padding:80px 0;background:var(--bg);}
    .builders-grid{display:grid;grid-template-columns:1fr 1fr;gap:50px;align-items:center;}
    .builders-text p{color:var(--text2);line-height:1.7;margin-bottom:20px;}
    .bl{list-style:none;margin-bottom:24px;}
    .bl li{position:relative;padding-left:24px;color:var(--text2);margin-bottom:10px;font-size:.95rem;line-height:1.5;}
    .bl li::before{content:'✓';position:absolute;left:0;color:var(--accent);font-weight:800;font-size:.85rem;}
    .builders-img{border-radius:8px;overflow:hidden;}
    .builders-img img{width:100%;aspect-ratio:4/3;object-fit:cover;}
    .builders-creds{display:flex;gap:16px;flex-wrap:wrap;}
    .bc{background:var(--bg2);border:1px solid var(--border);border-radius:4px;padding:10px 16px;font-family:var(--fd);font-weight:600;font-size:.9rem;color:var(--text2);}
    .bc-label{color:var(--accent2);margin-right:8px;font-weight:700;}

    /* ── PRICING ──────────────────────────── */
    .pricing{padding:80px 0;background:var(--bg2);border-top:1px solid var(--border);border-bottom:1px solid var(--border);}
    .pricing-sub{text-align:center;color:var(--text3);max-width:600px;margin:-30px auto 40px;font-size:.95rem;}
    .pricing-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px;}
    .pricing-card{background:var(--bg3);border:1px solid var(--border);border-radius:6px;padding:28px 24px;}
    .pc-main{border-color:var(--accent);background:rgba(204,255,0,.04);}
    .pricing-card h3{font-family:var(--fd);font-weight:700;font-size:1rem;color:var(--accent2);text-transform:uppercase;letter-spacing:.06em;margin-bottom:18px;padding-bottom:12px;border-bottom:1px solid var(--border);}
    .rr{display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-bottom:1px solid rgba(36,48,68,.5);}
    .rr:last-child{border-bottom:none;}
    .rr span{color:var(--text3);font-size:.88rem;}
    .rr strong{color:var(--white);font-family:var(--fd);font-weight:700;font-size:1rem;white-space:nowrap;}

    /* ── SERVICE AREA ────────────────────── */
    .area{padding:70px 0;background:var(--bg);}
    .area-tags{display:flex;flex-wrap:wrap;justify-content:center;gap:10px;margin-bottom:16px;}
    .area-tag{background:var(--bg2);border:1px solid var(--border);color:var(--text);font-family:var(--fd);font-weight:600;font-size:.85rem;padding:8px 16px;border-radius:4px;}
    .at-p{border-color:var(--accent);color:var(--accent2);background:rgba(204,255,0,.06);}
    .route-tags{display:flex;flex-wrap:wrap;justify-content:center;gap:8px;margin-top:12px;}
    .route-tag{background:rgba(204,255,0,.1);border:1px solid rgba(204,255,0,.25);color:var(--accent2);font-family:var(--fd);font-weight:700;font-size:.8rem;padding:5px 14px;border-radius:3px;}

    /* ── CONTACT ──────────────────────────── */
    .contact{padding:80px 0;background:var(--bg2);border-top:3px solid var(--accent);}
    .contact-grid{display:grid;grid-template-columns:1fr 1fr;gap:50px;align-items:start;}
    .contact-title{font-family:var(--fd);font-weight:800;font-size:clamp(1.6rem,3vw,2.4rem);color:var(--white);text-transform:uppercase;margin-bottom:12px;}
    .contact-info p{color:var(--text2);margin-bottom:24px;line-height:1.6;}
    .contact-method{display:flex;align-items:center;gap:14px;padding:16px;background:var(--bg3);border:1px solid var(--border);border-radius:6px;text-decoration:none;color:var(--text);margin-bottom:12px;transition:border-color .2s;}
    .contact-method:hover{border-color:var(--accent);}
    .contact-method svg{width:22px;height:22px;color:var(--accent2);flex-shrink:0;}
    .contact-method strong{color:var(--white);display:block;font-size:1rem;}
    .contact-method span{color:var(--text3);font-size:.85rem;}
    .contact-addr{margin-top:24px;color:var(--text3);font-size:.88rem;line-height:1.7;}
    .contact-addr strong{color:var(--text2);}
    .cf{display:grid;grid-template-columns:1fr 1fr;gap:14px;}
    .fg{display:flex;flex-direction:column;gap:4px;}
    .fg-full{grid-column:span 2;}
    .cf label{font-family:var(--fd);font-weight:600;font-size:.8rem;color:var(--text3);text-transform:uppercase;letter-spacing:.06em;}
    .cf input,.cf textarea{background:var(--bg);border:1px solid var(--border);border-radius:4px;padding:12px 14px;color:var(--white);font-family:var(--fb);font-size:.95rem;transition:border-color .2s;}
    .cf input:focus,.cf textarea:focus{outline:none;border-color:var(--accent);}
    .cf textarea{resize:vertical;}
    .cf .btn-primary{grid-column:span 2;justify-content:center;margin-top:4px;}

    /* ── FOOTER ───────────────────────────── */
    .footer{background:var(--bg);border-top:1px solid var(--border);padding:40px 0;}
    .footer-inner{display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:16px;}
    .footer-brand{display:flex;align-items:center;gap:12px;}
    .footer-logo{height:36px;width:auto;}
    .footer-brand strong{color:var(--white);font-family:var(--fd);font-size:1rem;text-transform:uppercase;}
    .footer-brand span{color:var(--text4);font-size:.8rem;}
    .footer p{color:var(--text4);font-size:.85rem;}
    .footer a{color:var(--accent2);text-decoration:none;}

    /* ── MOBILE STICKY CTA ───────────────── */
    .mobile-cta{display:none;position:fixed;bottom:0;left:0;right:0;background:var(--accent);padding:14px 24px;z-index:200;box-shadow:0 -4px 20px rgba(0,0,0,.4);}
    .mobile-cta a{display:flex;align-items:center;justify-content:center;gap:10px;color:var(--bg);font-family:var(--fd);font-weight:800;font-size:1.2rem;text-decoration:none;text-transform:uppercase;}
    .mobile-cta svg{width:22px;height:22px;}

    /* ── RESPONSIVE ───────────────────────── */
    @media(max-width:900px){
      .move-grid{grid-template-columns:repeat(2,1fr);}
      .fleet-stats{grid-template-columns:repeat(2,1fr);}
      .builders-grid{grid-template-columns:1fr;gap:40px;}
      .pricing-grid{grid-template-columns:1fr;}
      .contact-grid{grid-template-columns:1fr;}
      .fleet-grid{grid-template-columns:1fr;}
      .fleet-wide{grid-column:span 1;}
    }
    @media(max-width:640px){
      .hero{min-height:auto;}
      .hero-overlay{background:linear-gradient(180deg,rgba(10,12,15,.6) 0%,rgba(10,12,15,.45) 40%,rgba(10,12,15,.7) 100%);}
      .hero h1{font-size:2rem;text-shadow:0 2px 12px rgba(0,0,0,.7);}
      .hero-sub{font-size:.95rem;text-shadow:0 1px 6px rgba(0,0,0,.5);}
      .hero-badge{text-shadow:none;}
      .hero-content{padding:50px 0 60px;}
      .move-grid{grid-template-columns:1fr;}
      .fleet-stats{grid-template-columns:1fr 1fr;}
      .cred-items{gap:16px 24px;}
      .cred-divider{display:none;}
      .header-text{display:none;}
      .mobile-cta{display:block;}
      body{padding-bottom:60px;}
      .header-phone a{font-size:.95rem;padding:8px 16px;}
      .cf{grid-template-columns:1fr;}
      .fg-full,.cf .btn-primary{grid-column:span 1;}
      .footer-inner{flex-direction:column;text-align:center;}
      .hero-actions{flex-direction:column;align-items:center;}
      .btn-primary,.btn-secondary{width:100%;justify-content:center;}
    }
  </style>
</head>
<body>
  <slot />
</body>
</html>
