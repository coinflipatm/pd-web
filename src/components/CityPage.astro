---
import Base from '../layouts/Base.astro';
import { PHONE, PHONE_LINK, BRAND, TAGLINE, services, trustSignals } from '../lib/cities.js';

const { city } = Astro.props;
const year = new Date().getFullYear();
const phoneSvg = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>`;
---

<Base title={city.meta.title} description={city.meta.description} canonical={`https://towtruck.cv/${city.slug === 'michigan' ? '' : city.slug}`}>

  <!-- HEADER -->
  <header class="header">
    <div class="header-inner">
      <div class="header-brand">
        <img src="/logo.svg" alt="Stinger Heavy Haul - Skeeter the Mosquitow" class="header-logo" />
        <div class="header-text">
          <div class="header-name">{BRAND}</div>
          <div class="header-tagline">{TAGLINE}</div>
        </div>
      </div>
      <div class="header-phone">
        <a href={PHONE_LINK}>
          <Fragment set:html={phoneSvg} />
          {PHONE}
        </a>
      </div>
    </div>
  </header>

  <!-- HERO -->
  <section class="hero">
    <div class="container">
      <div class="hero-badge">Serving {city.isState ? 'All of Michigan' : `${city.name}, ${city.state}`}</div>
      <h1>{city.isState ? (
        <>Heavy Equipment<br /><span>Hauling & Transport</span></>
      ) : (
        <>{city.name} <span>Heavy Equipment Hauling</span></>
      )}</h1>
      <p class="hero-sub">{city.description}</p>
      <a href={PHONE_LINK} class="hero-cta">
        <Fragment set:html={phoneSvg} />
        Call for a Free Quote
      </a>
    </div>
  </section>

  <!-- TRUST BAR -->
  <section class="trust-bar">
    <div class="container">
      <div class="trust-items">
        {trustSignals.map(s => <div class="trust-item">{s}</div>)}
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="services">
    <div class="container">
      <div class="section-label">What We Haul</div>
      <h2 class="section-title">Equipment Transport Services</h2>
      <div class="services-grid">
        {services.map(s => (
          <div class="service-card">
            <div class="service-icon">{s.icon}</div>
            <h3>{s.name}</h3>
            <p>{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ABOUT / CAPABILITY -->
  <section class="about">
    <div class="container">
      <div class="about-grid">
        <div class="about-text">
          <h2>Built for Michigan Heavy Haul</h2>
          <p>
            We're not a broker. We're not a dispatch service routing your call to the cheapest available truck. <strong>We own the equipment. We do the work.</strong>
          </p>
          <p>
            Our fleet includes hydraulic recovery trailers rated for Michigan's maximum legal weight — up to <strong>164,000 lbs</strong> with proper axle configuration. We have hands-on experience operating SkyTraks, telehandlers with attachments, and man boxes. When we load your equipment, we know exactly what we're handling.
          </p>
          <p>
            One call. We show up, load, secure, transport, and deliver. No middleman, no markup from a dispatch broker. Direct service at direct pricing.
          </p>
        </div>
        <div class="about-stats">
          <div class="stat-card">
            <div class="stat-number">164K</div>
            <div class="stat-label">Max LBS in Michigan</div>
          </div>
          <div class="stat-card">
            <div class="stat-number">7/7</div>
            <div class="stat-label">Days a Week</div>
          </div>
          <div class="stat-card">
            <div class="stat-number">Direct</div>
            <div class="stat-label">Owner-Operated</div>
          </div>
          <div class="stat-card">
            <div class="stat-number">MI</div>
            <div class="stat-label">DOT Compliant</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- AREA COVERAGE -->
  <section class="coverage">
    <div class="container">
      <div class="section-label">Service Area</div>
      <h2 class="section-title">{city.isState ? 'Statewide Coverage' : `${city.name} & Surrounding Areas`}</h2>
      <div class="coverage-text">
        <div class="area-tags">
          {city.areas.map(a => <span class="area-tag">{a}</span>)}
        </div>
        <div class="route-tags" style="margin-top: 16px;">
          {city.interstates.map(r => <span class="route-tag">{r}</span>)}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container">
      <h2>Get a Quote. Get It Moved.</h2>
      <p class="cta-sub">Tell us what you need hauled and where it's going. We'll give you a straight price.</p>
      <a href={PHONE_LINK} class="hero-cta">
        <Fragment set:html={phoneSvg} />
        Call {PHONE}
      </a>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <p>&copy; {year} {BRAND}. All rights reserved. <a href={PHONE_LINK}>{PHONE}</a></p>
  </footer>

  <!-- MOBILE STICKY CTA -->
  <div class="mobile-cta">
    <a href={PHONE_LINK}>
      <Fragment set:html={phoneSvg} />
      Call {PHONE}
    </a>
  </div>

  <!-- SCHEMA: LOCAL BUSINESS -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": BRAND,
    "description": city.meta.description,
    "telephone": "+18103945937",
    "url": `https://towtruck.cv/${city.slug === 'michigan' ? '' : city.slug}`,
    "areaServed": city.areas.map(a => ({ "@type": "City", "name": a })),
    "serviceType": services.map(s => s.name),
    "openingHours": "Mo-Su 00:00-23:59",
    "priceRange": "$$$",
  })} />

</Base>
